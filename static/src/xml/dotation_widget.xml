<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="stock_addons.DotationHistoryWidget" owl="1">
        <t t-if="isApplicable">
            <div class="o_dotation_widget">
                <span role="button" t-on-click.stop="togglePopup" class="btn btn-link btn-sm p-0">
                    <i t-if="!state.loading" class="fa fa-history"/>
                    <i t-else="" class="fa fa-spinner fa-spin"/>
                </span>
                <div class="o_dotation_popup bg-white border rounded shadow p-2"
                     t-if="state.showPopup and state.history"
                     style="position: absolute; z-index: 1000; min-width: 200px;">
                    <ul class="list-unstyled mb-0">
                        <t t-foreach="state.history" t-as="dot" t-key="dot_index">
                            <li>
                                <strong>
                                    <t t-if="dot_index == 0">Última dotación: </t>
                                    <t t-elif="dot_index == 1">Penúltima dotación: </t>
                                </strong>
                                <t t-esc="dot.date"/> - <t t-esc="dot.picking_name"/>
                            </li>
                        </t>
                        <t t-if="!state.history.length">
                            <li class="text-muted">Sin historial</li>
                        </t>
                    </ul>
                </div>
            </div>
        </t>
        <!-- Si no aplica, no se renderiza nada, columna vacía -->
    </t>
</templates>