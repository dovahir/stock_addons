<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_request_selection_wizard_form" model="ir.ui.view">
        <field name="name">request.selection.wizard.form</field>
        <field name="model">request.selection.wizard</field>
        <field name="arch" type="xml">
            <form string="Seleccionar solicitud de stock">
                <group>
                    <field name="requisition_id" invisible="1"/>
                    <field name="wizard_line_ids" invisible="1"/>
                    <field name="stock_request_id"
                           options="{'no_create': True}"/>
                    <field name="request_date" invisible="1"/>
                    <field name="scheduled_date"/>
                    <field name="state"/>
                    <field name="location_id" readonly="1" force_save="1"/>
                </group>
                <footer>
                    <button string="Agregar" name="action_add_to_request" type="object" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>