<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stock_request_block_wizard_form" model="ir.ui.view">
        <field name="name">stock.request.block.wizard.form</field>
        <field name="model">stock.request.block.wizard</field>
        <field name="arch" type="xml">
            <form string="Ocultar solicitud">
                <sheet>
                    <div class="text-left">
                        <strong>¿Está seguro de que desea ocultar esta solicitud? Ya no podrá agregar productos desde requisiciones.</strong>
                    </div>
                    <group>
                        <field name="request_id" invisible="1"/>
                        <field name="create_new"
                               help="Marque si desea crear una nueva solicitud de suministro automáticamente"/>
                        <field name="scheduled_date" help="Fecha de entrega estimada para la nueva solicitud"
                               invisible="not create_new"
                               required="create_new"
                               widget="datetime"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" string="Aceptar" type="object" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_stock_request_block_wizard" model="ir.actions.act_window">
        <field name="name">Ocultar solicitud</field>
        <field name="res_model">stock.request.block.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_stock_request"/>
    </record>
</odoo>