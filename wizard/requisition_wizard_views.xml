<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_requisition_wizard_form" model="ir.ui.view">
        <field name="name">requisition.wizard.form</field>
        <field name="model">requisition.wizard</field>
        <field name="arch" type="xml">
            <form string="Enviar a Stock Request">
                <group>
                    <field name="requisition_id" invisible="1"/>
                    <field name="line_ids" mode="tree" create="false" delete="false">
                        <tree>
                            <field name="selected" widget="boolean_toggle"/>
                            <field name="product_id" readonly="1"/>
                            <field name="quantity"/>
                            <field name="uom_id" readonly="1"/>
                        </tree>
                    </field>
                </group>
                <footer>
                    <button name="action_create_new_stock_request" string="Crear nuevo Stock Request" type="object" class="btn-primary"/>
                    <button name="action_add_to_existing_stock_request" string="Agregar a Stock Request existente" type="object"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_requisition_wizard" model="ir.actions.act_window">
        <field name="name">Solicitar suministro</field>
        <field name="res_model">requisition.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="employee_purchase_requisition.model_employee_purchase_requisition"/>
        <field name="binding_view_types">form</field>
    </record>
</odoo>