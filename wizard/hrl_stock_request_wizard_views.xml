<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hrl_stock_request_wizard_form" model="ir.ui.view">
        <field name="name">hrl.stock.request.wizard.form</field>
        <field name="model">hrl.stock.request.wizard</field>
        <field name="arch" type="xml">
            <form string="Agregar a Solicitud Existente">
                <group>
                    <field name="request_id" widget="many2one" options="{'no_create': True}" string="Seleccione una solicitud"/>
                    <field name="move_ids" invisible="1"/> <!-- oculto, solo para pasar contexto -->
                </group>
                <footer>
                    <button name="action_add_moves" string="Agregar" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>