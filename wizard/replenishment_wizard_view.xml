<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_replenishment_wizard_form" model="ir.ui.view">
        <field name="name">replenishment.wizard.form</field>
        <field name="model">replenishment.wizard</field>
        <field name="arch" type="xml">
            <form string="Reabastecer a Base">
                <sheet>
                    <group>
                        <field name="purchase_order_id"
                               options="{'no_create': True}"
                               placeholder="Seleccione una cotización en borrador"/>
                    </group>
                    <field name="line_ids" nolabel="1" mode="tree">
                        <tree editable="bottom" create="false" delete="false" open="false">
                            <field name="product_id" readonly="1"/>
                            <field name="product_qty" string="Cantidad" decoration-bf="1"/>
                            <field name="uom_id" readonly="1"/>
                            <field name="note"/>
                        </tree>
                    </field>
                </sheet>
                <footer>
                    <button name="action_add_to_order" string="Reabastecer" type="object" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>