<?xml version="1.0"?>

<odoo>
<!--    Vista tree  -->
    <record id="view_stock_request_tree" model="ir.ui.view">
        <field name="name">stock.request.tree</field>
        <field name="model">stock.request</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" decoration-bf="1"/>
                <field name="requisition_ids" widget="many2many_tags"/>
                <field name="warehouse_id" optional="show"/>
                <field name="location_id" string="Origen" optional="show"/>
                <field name="location_dest_id" string="Destino" optional="show"/>
                <field name="request_uid" optional="hide"/>
                <field name="request_date" optional="hide"/>
                <field name="scheduled_date" optional="show"/>
                <field name="state" widget='badge' optional="show"
                       decoration-muted="state == 'draft'"
                       decoration-info="state == 'confirm'"
                       decoration-success="state == 'validate'"
                       decoration-danger="state =='cancel'"/>
            </tree>
       </field>
    </record>

<!--    Formulario  -->
    <record id="view_stock_request_form" model="ir.ui.view">
        <field name="name">stock.request.form</field>
        <field name="model">stock.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_create_delivery"
                            string="Crear Entrega"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>

                    <button name="action_button_cancel"
                            string="Cancelar"
                            type="object"
                            invisible="state in ('done_exact', 'done_partial', 'done_adjusted', 'cancel')"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,delivery_created,in_transit,done_exact"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                    	<button type="object" name="action_view_outgoing" class="oe_stat_button" icon="fa-truck">
                            <field name="outgoing_count" widget="statinfo" string="Entrega"/>
                        </button>
                        <button type="object" name="action_view_incoming" class="oe_stat_button" icon="fa-truck">
                            <field name="incoming_count" widget="statinfo" string="Recepción"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1 class="d-flex">
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group col="3" colspan="3">
                        <group string="Informacion">
                            <field name="company_id" invisible="1"/>
                            <field name="request_uid" force_save="1"/>
                            <field name="request_date" force_save="1"/>
                            <field name="scheduled_date" readonly="state != 'draft'"/>
                            <field name="requisition_ids" widget="many2many_tags" optional="show"
                                   readonly="1" force_save="1"/>
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}" force_save="1"/>
                        </group>
                        <group string="Origen">
                            <field name="picking_type_id" options="{'no_create': True}" readonly="state != 'draft'" string="Tipo de operación"
                                   domain="[('code','=', 'internal'), ('name', 'ilike', 'enviar')]"/>
                            <field name="warehouse_id" options="{'no_create': True}"
                                   domain="[('company_id','=', company_id)]" readonly="1" force_save="1"/>
                            <field name="location_id" options="{'no_create': True}" string="Ubicación"
                                   domain="[('usage','=', 'internal'),('warehouse_id','=', warehouse_id)]" readonly="1" force_save="1"/>
                        </group>
                        <group string="Destino">
                            <field name="picking_type_dest_id" options="{'no_create': True}" domain="[('code','=', 'incoming')]" readonly="state != 'draft'" string="Tipo de operación"/>
                            <field name="location_dest_id" options="{'no_create': True}" string="Ubicación"
                                   domain="[('usage','=', 'internal')]" readonly="1" force_save="1"/>
                            <field name="warehouse_dest_id" invisible="1"/>
                        </group>
                        <field name="notes" readonly="state != 'draft'" placeholder="Escriba aquí sus notas"/>
                        <field name="delivery_alert" invisible="1"/>
                    </group>
                    <div class="alert alert-success text-center" role="alert"
                         invisible="state not in ('in_transit', 'done_exact', 'done_partial', 'done_adjusted') or delivery_alert != 'exact'">
                        <i class="fa fa-check-circle"/> Todos los productos de la solicitud fueron trasladados exactamente.
                    </div>

                    <div class="alert alert-warning text-center" role="alert"
                         invisible="state not in ('in_transit', 'done_exact', 'done_partial', 'done_adjusted') or delivery_alert != 'less'">
                        <i class="fa fa-exclamation-triangle"/> Atención: Se han retirado uno o más productos de la solicitud original, o la cantidad trasladada fue menor.
                    </div>

                    <div class="alert alert-info text-center" role="alert"
                         invisible="state not in ('in_transit', 'done_exact', 'done_partial', 'done_adjusted') or delivery_alert != 'more'">
                        <i class="fa fa-info-circle"/> Aviso: Se han añadido productos no solicitados o la cantidad trasladada superó la original.
                    </div>
                    <notebook>
                        <page string="Productos">
                            <field name="line_ids" nolabel="1" mode="tree" readonly="state != 'draft'">
                                <tree editable="bottom" create="true" delete="true" open_form="false">
                                    <field name="requisition_id" optional="show" widget="many2one"/>
                                    <field name="product_id" options="{'no_create': True}" domain="[('type','in', ['product','consu'])]"/>
                                    <field name="name" string="Descripción" optional="show"/>
                                    <field name="product_qty" decoration-bf="1"/>
                                    <field name="product_uom_id" options="{'no_create': True}"/>
                                    <field name="requester_name" optional="show" readonly="1"/>
                                    <field name="requisition_deadline" optional="show" string="Fecha entrega"/>
                                    <field name="note" optional="show"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                   <field name="message_follower_ids" groups="base.group_user"/>
                   <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>


    <record id="view_stock_request_search" model="ir.ui.view">
        <field name="name">stock.request.search</field>
        <field name="model">stock.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Numero de solicitud" filter_domain="[('name', 'ilike', self)]"/>
                <separator/>
                <filter string="Borrador" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmado" name="filter_confirm" domain="[('state', '=', 'confirm')]"/>
                <filter string="Validado" name="filter_validate" domain="[('state', '=', 'validate')]"/>
                <filter string="Cancelado" name="cancel" domain="[('state', '=', 'cancel')]"/>
                <separator/>
                <filter name="my_request" string="Mis solicitudes" domain="[('request_uid', '=', uid)]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Almacén" name="group_by_warehouse_id" domain="[]" context="{'group_by': 'warehouse_id'}"/>
                    <filter string="Fecha de solicitud" name="group_by_request_date" domain="[]" context="{'group_by': 'request_date'}"/>
                    <filter string="Fecha programada" name="group_by_scheduled_date" domain="[]" context="{'group_by': 'scheduled_date'}"/>
                    <filter string="Estado" name="group_by_state" domain="[]" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

<!--    Herencias   -->


    <record id="stock_addons_inherit_purchase_requisition_form" model="ir.ui.view">
        <field name="name">stock_addons.requisition.form.inherit</field>
        <field name="model">employee.purchase.requisition</field>
        <field name="inherit_id" ref="employee_purchase_requisition.purchase_requisition_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@class='oe_button_box']" position="inside">
                <button class="oe_stat_button" type="object"
                        name="get_stock_request"
                        icon="oi-view-list"
                        invisible="stock_request_count == 0 or state not in ('approved','purchase_order_created','parc') or tipo_requisicion == 'serv'">
                    <field string="Solicitudes de suministro"
                           name="stock_request_count"
                           widget="statinfo"
                    />
                </button>
            </xpath>
        </field>
    </record>

    <record id="view_picking_type_form_inherit" model="ir.ui.view">
        <field name="name">stock.picking.type.form.inherit</field>
        <field name="model">stock.picking.type</field>
        <field name="inherit_id" ref="stock.view_picking_type_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='locations']" position="inside">
                <field name="default_dest_picking_type"
                       options="{'no_create': True, 'no_open': True}"
                       invisible="code not in ('internal')"
                       domain="[('code', '=', 'incoming')]"/>
            </xpath>
        </field>
    </record>

<!--    Smartbutton para ver solicitud de suministro origen en stock.picking-->
    <record id="stock_picking_form_inherit_stock_request_button" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.stock.request.button</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <field name="stock_request_id" invisible="1"/>
                <button name="action_open_stock_request"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-file-text-o"
                        invisible="not stock_request_id">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Suministro origen</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

<!--    Action para el form-->
    <record id="action_stock_request" model="ir.actions.act_window">
        <field name="name">Solicitudes de suministro</field>
        <field name="res_model">stock.request</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[]</field>
        <field name="context">{'search_default_my_request': 1}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Aquí aparecerán tus solicitudes!
            </p>
        </field>
    </record>

</odoo>