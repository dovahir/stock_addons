<?xml version="1.0"?>

<odoo>
<!--    Vista tree  -->
    <record id="view_stock_request_tree" model="ir.ui.view">
        <field name="name">stock.request.tree</field>
        <field name="model">stock.request</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" decoration-bf="1"/>
                <field name="requisition_ids" widget="many2many_tags"/>
                <field name="warehouse_id" optional="show"/>
                <field name="location_id" string="Origen" optional="show"/>
                <field name="location_dest_id" string="Destino" optional="show"/>
                <field name="request_uid" optional="hide"/>
                <field name="request_date" optional="hide"/>
                <field name="scheduled_date" optional="show"/>
                <field name="state" widget='badge' optional="show"
                       decoration-muted="state == 'draft'"
                       decoration-info="state == 'delivery_created'"
                       decoration-primary="state == 'in_transit'"
                       decoration-success="state == 'done_exact' or state == 'done_adjusted'"
                       decoration-warning="state == 'done_partial'"
                       decoration-danger="state in ('cancel', 'delivery_returned', 'receipt_cancelled')"/>
            </tree>
       </field>
    </record>

<!--    Formulario  -->
    <record id="view_stock_request_form" model="ir.ui.view">
        <field name="name">stock.request.form</field>
        <field name="model">stock.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_create_delivery"
                            string="Crear Entrega"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'draft'"
                            groups="stock_addons.group_stock_request_employee"
                            confirm="¿Está seguro de que desea crear la entrega? Esta acción generará la salida y ya no podrá agregar productos."/>

                    <button name="action_open_transfer_wizard"
                            string="Transferir pendientes"
                            type="object"
                            class="oe_highlight"
                            invisible="delivery_alert != 'backorder_pending'"
                            groups="stock_addons.group_stock_request_employee"/>

                    <button name="action_button_draft"
                            string="Regresar a borrador"
                            type="object"
                            groups="stock_addons.group_stock_request_employee"
                            invisible="delivery_alert in ('returned') or
                                    state not in ('delivery_returned', 'cancel')"/>

                    <button name="action_button_cancel"
                            string="Cancelar"
                            type="object"
                            groups="stock_addons.group_stock_request_employee"
                            invisible="state in ('done_exact', 'done_partial', 'done_adjusted', 'cancel', 'delivery_returned')"/>

<!--                    Botones para bloquear solicitud en requisiciones-->
                    <button name="action_open_block_wizard"
                            string="Hacer corte"
                            type="object"
                            class="btn-secondary"
                            groups="stock_addons.group_stock_request_employee"
                            invisible="state != 'draft' or not id or not picking_type_id or is_blocked"/>

                    <button name="action_button_is_blocked"
                            string="Mostrar solicitud"
                            type="object"
                            groups="stock_addons.group_stock_request_employee"
                            invisible="state != 'draft' or not id or not picking_type_id or not is_blocked"
                            confirm="¿Está seguro de que desea mostrar esta solicitud? Podrá agregar productos desde requisiciones."/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,delivery_created,in_transit,done_exact"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                    	<button type="object" name="action_view_outgoing" class="oe_stat_button" icon="fa-truck">
                            <field name="outgoing_count" widget="statinfo" string="Entrega"/>
                        </button>
                        <button type="object" name="action_view_incoming" class="oe_stat_button" icon="fa-truck">
                            <field name="incoming_count" widget="statinfo" string="Recepción"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1 class="d-flex">
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group col="3" colspan="3">
                        <group string="Informacion">
                            <field name="company_id" invisible="1" />
                            <field name="request_uid" widget="many2one_avatar_user" force_save="1"/>
                            <field name="request_date" force_save="1"/>
                            <field name="scheduled_date" readonly="state != 'draft'" help="Fecha programada para recibir los productos"/>
                            <field name="requisition_ids" widget="many2many_tags" optional="show"
                                   readonly="1" force_save="1"/>
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True, 'no_edit': True, 'no_open': True}" force_save="1"/>
                        </group>
                        <group string="Origen">
                            <field name="picking_type_id" options="{'no_create': True}" readonly="state != 'draft'" string="Tipo de operación"
                                   domain="[('code','=', 'internal'), ('name', 'ilike', 'enviar')]"
                                   help="Defina a donde enviará los productos, los demás campos se llenarán automáticamente"/>
                            <field name="warehouse_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}"
                                   domain="[('company_id','=', company_id)]" readonly="1" force_save="1"/>
                            <field name="location_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" string="Ubicación"
                                   domain="[('usage','=', 'internal'),('warehouse_id','=', warehouse_id)]" readonly="1" force_save="1"/>
                        </group>
                        <group string="Destino">
                            <field name="picking_type_dest_id" string="Tipo de operación"
                                   options="{'no_create': True, 'no_edit': True, 'no_open': True}"
                                   domain="[('code','=', 'incoming')]"
                                   readonly="1" force_save="1"/>
                            <field name="location_dest_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" string="Ubicación"
                                   domain="[('usage','=', 'internal')]" readonly="1" force_save="1"/>
                            <field name="warehouse_dest_id" invisible="1"/>
                        </group>
                        <field name="notes" readonly="state != 'draft'" placeholder="Escriba aquí sus notas"/>

<!--                        Para estados-->
                        <field name="delivery_alert" invisible="1"/>
                        <field name="return_type" invisible="1"/>
                        <field name="is_blocked" invisible="1"/>
                        <field name="has_transferred_lines" invisible="1"/>
                    </group>

<!--                    Divs de alertas-->
                    <div class="alert alert-info text-center" role="alert"
                         invisible="state != 'draft' or not id or not picking_type_id">
                        <i class="fa fa-info-circle" title="Información"/>
                        Solicitud en proceso, puede seguir agregando productos desde las requisiciones o manualmente.
                        <button name="action_open_requisitions"
                                type="object"
                                string="Ir a Requisiciones"
                                class="btn btn-sm btn-primary ms-2"
                                icon="fa-file-text-o"/>
                    </div>

                    <div class="alert alert-danger text-center" role="alert" invisible="delivery_alert != 'cancelled'">
                        <i class="fa fa-times-circle"/> La entrega asociada fue cancelada. Haga clic en "Regresar a borrador" para reintentar.
                    </div>
                    <div class="alert alert-danger text-center o_form_header"
                         role="status"
                         invisible="state != 'receipt_cancelled'">
                        <strong>¡Recepción Cancelada!</strong> Los productos no fueron recibidos en destino.
                        Los números de serie siguen asignados a este documento. Se recomienda hacer la devolución desde la entrega.
                    </div>
                    <div class="alert alert-info text-center" role="alert" invisible="state != 'in_transit'">
                        <i class="fa fa-truck"/> <strong>Productos en tránsito:</strong> La entrega ha sido validada y los productos están en camino al destino. Pendiente de recepción.
                    </div>

                    <div class="alert alert-warning text-center" role="alert"
                         invisible="state != 'delivery_created' or delivery_alert == 'cancelled'">
                        <i class="fa fa-list-alt"/> <strong>Entrega creada:</strong> El movimiento de salida ha sido creado. Por favor, proceda a validar el envío en el módulo de Inventario para iniciar el tránsito.
                    </div>
                    <div class="alert alert-warning text-center" role="alert"
                         invisible="delivery_alert != 'returned'">
                        <i class="fa fa-undo"/>
                        <strong>Entrega devuelta</strong>
                        <span invisible="return_type != 'total'"> (Total): </span>
                        <span invisible="return_type != 'partial'"> (Parcial): </span>
                        Los productos han regresado al almacén de origen.
                    </div>
                    <div class="alert alert-success text-center" role="alert"
                         invisible="state not in ('done_exact', 'done_partial', 'done_adjusted') or delivery_alert != 'exact'">
                        <i class="fa fa-check-circle"/> Todos los productos de la solicitud fueron trasladados.
                    </div>

                    <div class="alert alert-warning text-center" role="alert"
                         invisible="state not in ('done_exact', 'done_partial', 'done_adjusted') or delivery_alert != 'less'">
                        <i class="fa fa-exclamation-triangle"/> Atención: Se han retirado uno o más productos de la solicitud original, o la cantidad trasladada fue menor.
                    </div>

                    <div class="alert alert-info text-center" role="alert"
                         invisible="not has_transferred_lines">
                        <i class="fa fa-share"/>
                        <strong>Esta solicitud contiene líneas transferidas a otra solicitud</strong>
                    </div>

                    <div class="alert alert-info text-center" role="alert"
                         invisible="state not in ('done_exact', 'done_partial', 'done_adjusted') or delivery_alert != 'more'">
                        <i class="fa fa-info-circle"/> Aviso: Se han añadido productos no solicitados o la cantidad trasladada superó la original.
                    </div>
                    <div class="alert alert-warning text-center" role="alert"
                         invisible="delivery_alert != 'returned'">
                        <i class="fa fa-undo"/> <strong>Entrega devuelta:</strong> El albarán de salida fue devuelto. Los productos han regresado al almacén de origen.
                    </div>
                    <div class="alert alert-warning text-center" role="alert" invisible="delivery_alert != 'backorder_pending'">
                        <i class="fa fa-clock-o"/> <strong>Orden parcial pendiente:</strong> Existe una orden parcial que aún no ha sido validado. La recepción correspondiente se creará automáticamente al validar la orden.
                    </div>
                    <div class="alert alert-warning text-center" role="alert"
                         invisible="delivery_alert != 'cancelled_backorder'">
                        <i class="fa fa-ban"/>
                        <strong>Backorder cancelado:</strong> Los productos pendientes ya no se enviarán.
                    </div>
<!--                    Lineas de productos (stock.request.line)-->
                    <notebook>
                        <page string="Productos">
                            <field name="line_ids" nolabel="1" mode="tree" readonly="state != 'draft'">
                                <tree editable="bottom" create="true" delete="true" open_form="false">
                                    <field name="requisition_id" optional="show" widget="many2one"/>
                                    <field name="product_id" options="{'no_create': True}" domain="[('type','in', ['product','consu'])]"
                                           readonly="requisition_id"/>
<!--                                    <field name="name" string="Descripción" optional="show" readonly="1" force_save="1"/>-->
                                    <field name="request_qty" optional="show" readonly="1"/>
                                    <field name="product_qty" decoration-bf="1"/>
                                    <field name="product_uom_id" string="Unidad"
                                           options="{'no_create': True}" readonly="1" force_save="1"/>
                                    <field name="has_tracking" column_invisible="True"/>
                                    <field name="lot_ids" string="Num. de serie"
                                           widget="many2many_tags"
                                           options="{'no_create': True}"
                                           invisible="has_tracking == 'none'"
                                           required="has_tracking == 'serial'"
                                           optional="show"/>
                                    <field name="requester_name" optional="show" readonly="1"/>
                                    <field name="is_dotation" column_invisible="True"/>
                                    <field name="dotation_display" widget="dotation_history_widget" string="" optional="show"/>
                                    <field name="requisition_deadline" optional="show" string="Fecha entrega (Requisición)"/>
                                    <field name="note" optional="show"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                   <field name="message_follower_ids" groups="base.group_user"/>
                   <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_stock_request_search" model="ir.ui.view">
        <field name="name">stock.request.search</field>
        <field name="model">stock.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Numero de solicitud" filter_domain="[('name', 'ilike', self)]"/>
                <separator/>
                <filter string="Borrador" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmado" name="filter_confirm" domain="[('state', '=', 'confirm')]"/>
                <filter string="Validado" name="filter_validate" domain="[('state', '=', 'validate')]"/>
                <filter string="Cancelado" name="cancel" domain="[('state', '=', 'cancel')]"/>
                <separator/>
                <filter name="my_request" string="Mis solicitudes" domain="[('request_uid', '=', uid)]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Almacén" name="group_by_warehouse_id" domain="[]" context="{'group_by': 'warehouse_id'}"/>
                    <filter string="Fecha de solicitud" name="group_by_request_date" domain="[]" context="{'group_by': 'request_date'}"/>
                    <filter string="Fecha programada" name="group_by_scheduled_date" domain="[]" context="{'group_by': 'scheduled_date'}"/>
                    <filter string="Estado" name="group_by_state" domain="[]" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

<!--    Herencias   -->

    <record id="stock_addons_inherit_purchase_requisition_form" model="ir.ui.view">
        <field name="name">stock_addons.requisition.form.inherit</field>
        <field name="model">employee.purchase.requisition</field>
        <field name="inherit_id" ref="employee_purchase_requisition.purchase_requisition_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@class='oe_button_box']" position="inside">
                <button class="oe_stat_button" type="object"
                        name="get_stock_request"
                        groups="stock_addons.group_stock_request_employee, stock_addons.group_stock_request_planta"
                        icon="oi-view-list"
                        invisible="stock_request_count == 0 or state not in ('approved','purchase_order_created','parc') or tipo_requisicion == 'serv'">
                    <field string="Solicitudes de suministro"
                           name="stock_request_count"
                           widget="statinfo"
                    />
                </button>
            </xpath>
        </field>
    </record>

    <record id="view_picking_type_form_inherit" model="ir.ui.view">
        <field name="name">stock.picking.type.form.inherit</field>
        <field name="model">stock.picking.type</field>
        <field name="inherit_id" ref="stock.view_picking_type_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='locations']" position="inside">
                <field name="default_dest_picking_type"
                       options="{'no_create': True, 'no_open': True}"
                       invisible="code not in ('internal')"
                       domain="[('code', '=', 'incoming')]"/>
            </xpath>
        </field>
    </record>

<!--    herencia temporal para pruebas local ELIMINAR:-->
    <record id="purchase_order_form" model="ir.ui.view">
        <field name='name'>
            purchase.order.view.form.inherit.order.line.note
        </field>
        <field name='model'>purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <!-- Define the position to insert the new elements in the view -->
            <xpath expr="//tree/field[@name='name']" position="after">
                <field name="note" optional="show"/>
            </xpath>
        </field>
    </record>

<!--    Action para el form-->
    <record id="action_stock_request" model="ir.actions.act_window">
        <field name="name">Solicitudes de suministro</field>
        <field name="res_model">stock.request</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[]</field>
<!--        <field name="context">{'search_default_my_request': 1}</field>-->
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Aquí aparecerán todas las solicitudes!
            </p>
        </field>
    </record>

    <record id="action_stock_request_transfer_wizard" model="ir.actions.act_window">
        <field name="name">Transferir pendientes</field>
        <field name="res_model">stock.request.transfer.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{"default_original_request_id": active_id}</field>
    </record>

</odoo>