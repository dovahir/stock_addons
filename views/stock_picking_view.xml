<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!--    Smartbutton para ver solicitud de suministro origen en stock.picking-->
    <record id="stock_picking_form_inherit_stock_request_button" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.stock.request.button</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <field name="stock_request_id" invisible="1"/>
                <button name="action_open_stock_request"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-files-o"
                        invisible="not stock_request_id">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Suministro origen</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

<!--    Boton para imprimir reporte de traspaso desde picking-->
    <record id="stock_picking_form_inherit_report_button" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.report.button</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_print_report"
                        string="Imprimir traspaso"
                        type="object"
                        class="btn-secondary"
                        icon="fa-file-pdf-o"
                        invisible="not stock_request_id or state == 'cancel'"
                        groups="stock.group_stock_user"/>
            </xpath>
        </field>
    </record>

<!--    Campos de requisiciones origen e info-->
    <record id="view_picking_form_add_requisition_info" model="ir.ui.view">
        <field name="name">stock.picking.form.add.requisition.info</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='move_ids_without_package']/tree/field[@name='product_id']" position="before">
                <field name="line_number" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='move_ids_without_package']/tree/field[@name='product_id']" position="after">
                <field name="requisition_ids" widget="many2many_tags" optional="hide" readonly="1"/>
            </xpath>
        </field>
    </record>

</odoo>