<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Vista tree -->
        <record id="view_pending_send_tree" model="ir.ui.view">
            <field name="name">pending.send.tree</field>
            <field name="model">stock.move</field>
            <field name="arch" type="xml">
                <tree string="Productos Pendientes de Envío" default_order="create_date desc" create="false">
                    <field name="picking_id" string="Referencia" widget="many2one"/>
                    <field name="requisition_id" string="Requisicion" widget="many2one"/>
                    <field name="product_id" widget="many2one"/>
                    <field name="project_id"/>
                    <field name="task_id"/>
                    <field name="quantity" sum="Total Realizado" string="Cantidad disponible"/>
                    <field name="product_uom_qty" sum="Total Demandado"/>
                    <field name="remaining_qty" sum="Total Pendiente"/>
                    <field name="product_uom" string="Unidad"/>
                    <field name="picking_type_id"/>
                    <field name="location_id"/>
                    <field name="location_dest_id"/>
                    <field name="date"/>
                    <field name="state" widget='badge' optional="show"
                       decoration-danger="state=='cancel'"
                       decoration-info="state== 'assigned'"
                       decoration-muted="state == 'draft'"
                       decoration-success="state == 'done'"
                       decoration-warning="state not in ('draft','cancel','done','assigned')"/>
                </tree>
            </field>
        </record>

        <!-- Filtros -->
    <record id="view_pending_sent_search" model="ir.ui.view">
        <field name="name">pending.sent.search.inherit</field>
        <field name="model">stock.move</field>
        <field name="inherit_id" ref="stock.view_move_search"/>  <!-- ID de la vista original -->
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <group expand="1" string="Agrupar por">
                    <filter name="group_by_ref" string="Referencia"
                            context="{'group_by': 'picking_id'}"/>
                    <filter name="group_by_project" string="Proyecto"
                            context="{'group_by': 'project_id'}"/>
                    <filter name="group_by_task" string="Tarea"
                            context="{'group_by': 'task_id'}"/>
                    <filter name="group_by_requisition" string="Requisicion"
                            context="{'group_by': 'requisition_id'}"/>
                </group>
            </xpath>
        </field>
    </record>

        <!-- Action que filtra por pendientes de enviar -->
        <record id="action_pending_send" model="ir.actions.act_window">
            <field name="name">Pendientes de Envío</field>
            <field name="res_model">stock.move</field>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="view_pending_send_tree"/>
            <field name="domain">[('is_pending_send', '=', True), ("picking_type_id", "not ilike", "resguardo")]</field>
<!--            Agrupar por tipo de operación por defecto-->
<!--            <field name="context">{'group_by': 'picking_type_id'}</field>-->
        </record>

    </data>
</odoo>