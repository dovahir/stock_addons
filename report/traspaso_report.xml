<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="reporte_traspaso_document">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.external_layout">
                        <style>
                            .report-container {
                                font-family: 'DejaVu Sans', sans-serif;
                                font-size: 11pt;
                                line-height: 1.5;
                                margin: 0;
                                padding: 0;
                            }
                            .header-section {
                                margin-bottom: 8mm;
                                font-size: 14pt;
                                overflow: hidden; /* clearfix */
                            }
                            .header-left {
                                float: left;
                                width: 48%;
                            }
                            .header-right {
                                float: right;
                                width: 48%;
                                text-align: right; /* alinea a la derecha */
                            }
                            .header-left p,
                            .header-right p {
                                margin: 2px 0;
                            }
                            .header-right .folio-line {
                                /* para mantener folio y estado en la misma línea */
                            }
                            .items-table {
                                width: 100%;
                                border-collapse: collapse;
                                margin-top: 5mm;
                            }
                            .items-table th,
                            .items-table td {
                                border: 1px solid #ddd;
                                padding: 4px;
                                text-align: left;
                                vertical-align: top;
                            }
                            .items-table th {
                                background-color: #f2f2f2;
                                font-weight: bold;
                            }
                            .items-table td.number {
                                text-align: center;
                            }
                            .signature-table {
                                width: 100%;
                                margin-top: 15mm;
                                border-collapse: collapse;
                            }
                            .signature-cell {
                                width: 25%;
                                text-align: center;
                                vertical-align: top;
                                padding: 0 10mm;
                            }
                            .signature-line {
                                margin-top: 8mm;
                                border-top: 1px solid #000;
                                width: 60mm;
                                display: inline-block;
                            }
                            .signature-title {
                                margin-top: 2mm;
                                font-weight: bold;
                            }
                            .signature-name {
                                margin-top: 1mm;
                            }
                        </style>

                        <div class="report-container">
                            <div class="page">
                                <!-- CABECERA -->
                                <div class="header-section">
                                    <div class="header-right">
                                        <p><strong>Almacén origen:</strong> <span t-field="o.stock_request_id.warehouse_id"/></p>
                                        <p><strong>Almacén destino:</strong> <span t-field="o.stock_request_id.warehouse_dest_id"/></p>
                                    </div>
                                    <div class="header-left">
                                        <p class="folio-line">
                                            <strong>Folio:</strong> <span t-field="o.name"/>
                                            <strong style="margin-left: 10mm;">Estado:</strong> <span t-field="o.state"/>
                                        </p>
                                        <p><strong>Solicitud origen:</strong> <span t-field="o.stock_request_id.name"/></p>
                                        <p>
                                            <t t-if="o.date_done">
                                                <strong>Fecha programada:</strong>
                                                <span t-field="o.date_done"/>
                                            </t>
                                            <t t-else="">
                                                <strong>Fecha efectiva:</strong>
                                                <span t-field="o.scheduled_date"/>
                                            </t>
                                        </p>
                                    </div>
                                </div>

                                <!-- TABLA DE PRODUCTOS -->
                                <table class="items-table">
                                    <thead>
                                        <tr>
                                            <th>N°</th>
                                            <th>Descripción del producto</th>
                                            <th>Cantidad</th>
                                            <th>Unidad</th>
                                            <th>Número de serie</th>
                                            <th>Requisiciones</th>
                                            <th>Cantidad por Req.</th>
                                        </tr>
                                    </thead>
                                    <!-- El fragmento actual funciona, pero asegúrate de que sea así: -->
                                    <tbody>
                                        <t t-foreach="o.move_ids" t-as="move">
                                            <tr>
                                                <td class="number"><t t-esc="move_index + 1"/></td>
                                                <td><span t-field="move.product_id"/></td>
                                                <td class="number"><span t-field="move.quantity"/></td>
                                                <td><span t-field="move.product_uom.name"/></td>
                                                <td>
                                                    <t t-if="move.product_id.tracking == 'serial' and move.move_line_ids">
                                                        <t t-foreach="move.move_line_ids" t-as="line">
                                                            <span t-field="line.lot_id.name"/>
                                                            <t t-if="not line_last">, </t>
                                                        </t>
                                                    </t>
                                                    <t t-else="">-</t>
                                                </td>
                                                <td>
                                                    <t t-if="move.requisition_ids">
                                                        <span t-esc="', '.join(move.requisition_ids.mapped('name'))"/>
                                                    </t>
                                                    <t t-else="">STOCK</t>
                                                </td>
                                                <td>
                                                    <t t-if="move.requisition_ids">
                                                        <span t-field="move.requisition_info_text"/>
                                                    </t>
                                                    <t t-else="">STOCK</t>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>

                                <!-- FIRMAS -->
                                <table class="signature-table">
                                    <tr>
                                        <td class="signature-cell">
                                            <div class="signature-line"></div><br/>
                                            <div class="signature-title">ALMACÉN ORIGEN</div>
                                            <span t-esc="request.env.user.name"/>
                                            <div class="signature-name">Nombre y firma</div>
                                        </td>
                                        <td class="signature-cell">
                                            <div class="signature-line"></div><br/>
                                            <div class="signature-title">VIGILANCIA</div><br/>
                                            <div class="signature-name">Nombre y firma</div>
                                        </td>
                                        <td class="signature-cell">
                                            <div class="signature-line"></div><br/>
                                            <div class="signature-title">TRANSPORTISTA</div><br/>
                                            <div class="signature-name">Nombre y firma</div>
                                        </td>
                                        <td class="signature-cell">
                                            <div class="signature-line"></div><br/>
                                            <div class="signature-title">ALMACÉN DESTINO</div><br/>
                                            <div class="signature-name">Nombre y firma</div>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </template>
    </data>

    <record id="action_reporte_traspaso" model="ir.actions.report">
        <field name="name">Reporte de traspaso</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">stock_addons.reporte_traspaso_document</field>
        <field name="report_file">stock_addons.reporte_traspaso_document</field>
        <field name="print_report_name">'Reporte de traspaso'</field>
        <field name="paperformat_id" ref="paperformat_stock_addons_reports"/>
        <field name="binding_model_id" ref="stock.model_stock_picking"/>
        <field name="binding_type">report</field>
    </record>
</odoo>