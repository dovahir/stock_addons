<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="reporte_traspaso_document" t-name="stock_addons.reporte_traspaso_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <div class="report-container" style="font-family: 'DejaVu Sans', sans-serif; font-size: 10pt; line-height: 1.2;">
<!--                Para palabras acentuadas:-->
                    <meta charset="utf-8"/>
                    <!-- Estilos CSS -->
                    <style>
                        .custom-header {
                            height: 30mm;
                            padding: 5mm;
                            text-align: center;
                            border-bottom: 2px solid #2c3e50;
                            margin-bottom: 5mm;
                        }
                        .custom-header h2 {
                            margin: 0;
                            color: #2c3e50;
                            font-size: 14pt;
                        }
                        .custom-header h3 {
                            margin: 0;
                            color: #e74c3c;
                            font-size: 12pt;
                        }
                        .header-date {
                            font-size: 8pt;
                            color: #666;
                            margin-top: 2mm;
                        }
                        .custom-footer {
                            height: 15mm;
                            padding: 3mm;
                            text-align: center;
                            border-top: 1px solid #ccc;
                            font-size: 7pt;
                            color: #7f8c8d;
                            position: fixed;
                            bottom: 0;
                            width: 100%;
                            background: white;
                        }
                    </style>

                    <!-- Header -->
                    <div class="custom-header">
                        <h2>REPORTE DE TRASPASO</h2>
                        <h3><span t-field="o.name"/></h3>
                        <div class="header-date">
                            Fecha de emisión: <span t-field="o.create_date" t-options='{"widget": "date"}'/>
                        </div>
                    </div>

                    <!-- Contenido -->

                    <!-- Footer con numeración de páginas -->
                    <div class="custom-footer">
                        Página <span class="page"/> de <span class="topage"/>
                    </div>
                </div>
            </t>
        </t>
    </template>

    <record id="action_reporte_traspaso" model="ir.actions.report">
        <field name="name">Reporte de traspaso</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">stock_addons.reporte_traspaso_document</field>
        <field name="report_file">stock_addons.reporte_traspaso_document</field>
        <field name="print_report_name">'Reporte de traspaso'</field>
        <field name="paperformat_id" ref="paperformat_stock_addons_reports"/>
        <field name="binding_model_id" ref="stock.model_stock_picking"/>
        <field name="binding_type">report</field>
    </record>
</odoo>