<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="reporte_traspaso_document">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.external_layout">
                        <style>
                            /* ESTILOS GENERALES DEL REPORTE */
                            .report-container {
                                font-family: 'DejaVu Sans', sans-serif;
                                font-size: 10pt;
                                line-height: 1.2;
                            }

                            /* ESTILOS PARA CADA PÁGINA */
                            .page {
                                padding: 5mm;
                                margin-bottom: 10mm;
                            }

                            /* ESTILOS PARA TABLA DE PRODUCTOS */
                            .items-table {
                                width: 100%;
                                border-collapse: collapse;
                                margin-bottom: 10mm;
                            }
                            .items-table th,
                            .items-table td {
                                border: 1px solid #ddd;
                                padding: 4px;
                                text-align: left;
                                vertical-align: top;
                            }
                            .items-table th {
                                background-color: #f2f2f2;
                                font-weight: bold;
                            }
                            .items-table td.number {
                                text-align: center;
                            }

                            /* ESTILOS PARA TABLA DE FIRMAS (ya existente) */
                            .signature-table {
                                width: 100%;
                                font-size: 10pt;
                                border-collapse: collapse;
                            }
                            .signature-cell {
                                width: 25%;
                                text-align: center;
                                vertical-align: top;
                                padding: 0 10mm;
                            }
                            .signature-line {
                                margin-top: 10mm;
                                border-top: 1px solid #000;
                                width: 60mm;
                                display: inline-block;
                            }
                            .signature-title {
                                margin-top: 2mm;
                                font-weight: bold;
                            }
                        </style>

                        <div class="report-container">
                            <div class="page">
                                <!-- TABLA DE LÍNEAS DEL PICKING -->
                                <table class="items-table">
                                    <thead>
                                        <tr>
                                            <th>N°</th>
                                            <th>Descripción del producto</th>
                                            <th>Cantidad</th>
                                            <th>Unidad</th>
                                            <th>Requisición (de la línea)</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="o.move_ids" t-as="move">
                                            <tr>
                                                <td class="number"><t t-esc="move_index + 1"/></td>
                                                <td><span t-field="move.product_id.name"/></td>
                                                <td><span t-field="move.product_uom_qty"/></td>
                                                <td><span t-field="move.product_uom.name"/></td>
                                                <td>
                                                    <t t-if="move.requisition_id">
                                                        <span t-field="move.requisition_id.name"/>
                                                    </t>
                                                    <t t-elif="move.picking_id.requisition_order">
                                                        <span t-field="move.picking_id.requisition_order"/>
                                                    </t>
                                                    <t t-else="">
                                                        STOCK
                                                    </t>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>

                                <!-- TABLA DE FIRMAS -->
                                <div class="section-divider">
                                    <table class="table table-sm table-borderless signature-table">
                                        <tr>
                                            <td class="signature-cell">
                                                <div class="signature-space"></div>
                                                <div class="signature-line"></div><br/>
                                                <div class="signature-title">ALMACÉN REMITENTE</div><br/>
                                            </td>
                                            <td class="signature-cell">
                                                <div class="signature-space"></div>
                                                <div class="signature-line"></div><br/>
                                                <div class="signature-title">VIGILANCIA</div><br/>
                                            </td>
                                            <td class="signature-cell">
                                                <div class="signature-space"></div>
                                                <div class="signature-line"></div><br/>
                                                <div class="signature-title">TRANSPORTISTA</div><br/>
                                            </td>
                                            <td class="signature-cell">
                                                <div class="signature-space"></div>
                                                <div class="signature-line"></div><br/>
                                                <div class="signature-title">ALMACÉN DESTINO</div><br/>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </template>
    </data>

    <record id="action_reporte_traspaso" model="ir.actions.report">
        <field name="name">Reporte de traspaso</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">stock_addons.reporte_traspaso_document</field>
        <field name="report_file">stock_addons.reporte_traspaso_document</field>
        <field name="print_report_name">'Reporte de traspaso'</field>
        <field name="paperformat_id" ref="paperformat_stock_addons_reports"/>
        <field name="binding_model_id" ref="stock.model_stock_picking"/>
        <field name="binding_type">report</field>
    </record>
</odoo>