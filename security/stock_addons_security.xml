<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--        Categorias-->
    <record model="ir.module.category" id="category_stock_request">
        <field name="name">Solicitudes de suministro</field>
        <field name="sequence">25</field>
    </record>

    <record model="ir.module.category" id="category_stock_request_acceso">
        <field name="name">Suministros</field>
        <field name="sequence">1</field>
        <field name="parent_id" ref="category_stock_request"/>
    </record>

<!--    Grupos-->
    <record id="group_stock_request_only_read" model="res.groups">
        <field name="name">Usuarios</field>
        <field name="category_id" ref="category_stock_request_acceso"/>
    </record>

    <record id="group_stock_request_planta" model="res.groups">
        <field name="name">Empleados Almacén Planta</field>
        <field name="category_id" ref="category_stock_request_acceso"/>
    </record>

    <record id="group_stock_request_employee" model="res.groups">
        <field name="name">Empleados Almacén</field>
        <field name="category_id" ref="category_stock_request_acceso"/>
        <field name="implied_ids" eval="[(6, 0, [ref('stock.group_stock_manager')])]"/>
    </record>

    <data noupdate="1">

