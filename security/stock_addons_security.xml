        <record id="base.group_user" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('group_stock_request_only_read'))]"/>
        </record>

        <record model="ir.rule" id="stock_quant_report_rules">
            <field name="name">stock_quant_report multi-company</field>
            <field name="model_id" ref="model_stock_quant_report"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
        </record>

